#!/usr/bin/env bash
# Per-session Steam Big Picture launcher, invoked by Hermes as the "cmd" of the
# "Steam Big Picture" app (see entrypoint.sh / apps.json). Hermes runs this as
# root when a client starts the app and exports the stream's negotiated geometry
# in SUNSHINE_CLIENT_WIDTH/HEIGHT/FPS. We size gamescope to exactly that, so the
# picture is rendered natively (no upscaling) at whatever the Moonlight client
# asked for. gamescope is a nested Wayland client of the root-owned sway session;
# it runs as the non-root "steam" user (Steam refuses to run as root). When the
# client disconnects Hermes terminates this process group, tearing the session
# down — that's the "relaunch per connection" model (Steam is not kept warm).
#
# The boot-time prepare_steam() in entrypoint.sh has already granted the steam
# user GPU access, created its runtime dir, and opened the sway Wayland socket to
# it, so here we only compute the geometry and launch.
set -euo pipefail

# Mirror everything — our own messages plus gamescope/Steam output — to a stable
# log. Hermes runs this as an app cmd, so without this the output would only land
# in Hermes' own log; a fixed path makes each per-session launch easy to inspect.
# Append (don't truncate) so a failed session survives the client reconnecting to
# read it; a banner separates sessions.
STEAM_LOG=/var/log/steam.log
exec >>"${STEAM_LOG}" 2>&1

log()  { printf '\033[0;36m[hermes-steam]\033[0m %s\n' "$*" >&2; }
warn() { printf '\033[0;33m[hermes-steam][warn]\033[0m %s\n' "$*" >&2; }

log "=== session start $(date '+%F %T %Z') ==="

command -v steam >/dev/null 2>&1     || { warn "steam not installed; nothing to launch"; exit 0; }
command -v gamescope >/dev/null 2>&1 || { warn "gamescope not installed; nothing to launch"; exit 0; }
id steam >/dev/null 2>&1             || { warn "no 'steam' user; nothing to launch"; exit 0; }
# Honour the opt-out even though the app stays registered: exiting 0 makes Hermes
# fall back to streaming the plain desktop instead of Steam.
[ "${AUTOSTART_STEAM:-true}" = "true" ] || { log "AUTOSTART_STEAM=false; not launching Steam (streaming the desktop)"; exit 0; }
[ -n "${WAYLAND_DISPLAY:-}" ]        || { warn "no Wayland session (WAYLAND_DISPLAY unset)"; exit 1; }
[ -n "${XDG_RUNTIME_DIR:-}" ]        || { warn "XDG_RUNTIME_DIR unset"; exit 1; }

# Match the stream's negotiated geometry; fall back to the image defaults when
# Hermes does not export the client hints (log the raw values so a naming
# mismatch in this Hermes build is easy to spot in /var/log/steam.log).
W="${SUNSHINE_CLIENT_WIDTH:-${DISPLAY_WIDTH:-1920}}"
H="${SUNSHINE_CLIENT_HEIGHT:-${DISPLAY_HEIGHT:-1080}}"
R="${SUNSHINE_CLIENT_FPS:-${DISPLAY_REFRESH:-60}}"
log "client hints: WIDTH='${SUNSHINE_CLIENT_WIDTH:-}' HEIGHT='${SUNSHINE_CLIENT_HEIGHT:-}' FPS='${SUNSHINE_CLIENT_FPS:-}'"
log "launching Steam Big Picture at ${W}x${H}@${R} as user 'steam'"

runtime="/run/user/$(id -u steam)"
sockpath="${XDG_RUNTIME_DIR}/${WAYLAND_DISPLAY}"

# Belt-and-suspenders: re-open the socket to the steam user in case a fresh sway
# socket appeared after boot (idempotent, no-op when prepare_steam already did it).
install -d -o steam -g steam -m 700 "${runtime}" 2>/dev/null || true
chmod o+x "${XDG_RUNTIME_DIR}" 2>/dev/null || true
chmod o+rw "${sockpath}" 2>/dev/null || true

# Keep gamescope's primary child alive across Steam's own restarts. Steam
# re-execs itself after the first-run bootstrap ("Setting up Steam content") and
# on client updates, exiting the launched process; without the inner loop that
# would tear gamescope down ("Primary child shut down!") and end the session.
# gamescope itself stays up for the whole connection; Hermes kills this process
# group when the client disconnects.
exec runuser -u steam -- env \
    HOME=/config/steam \
    XDG_RUNTIME_DIR="${runtime}" \
    WAYLAND_DISPLAY="${sockpath}" \
    PULSE_SERVER="${PULSE_SERVER:-unix:/run/pulse/native}" \
    XDG_CURRENT_DESKTOP=gamescope \
    gamescope -W "${W}" -H "${H}" -r "${R}" -f -e -- \
    sh -c 'while :; do steam -gamepadui; printf "[hermes-steam] Steam exited (rc=%s); relaunching in 2s\n" "$?"; sleep 2; done'
